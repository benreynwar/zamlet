# Pass through environment variables for librelane flows
build --action_env=PATH
build --action_env=PDK_ROOT
build --action_env=PDK
# For linking against Nix Python (needed by cocotb)
build --action_env=LIBRARY_PATH
# User-specific sandbox paths are generated in .bazelrc.user by shell.nix
try-import %workspace%/.bazelrc.user